# --- Datenbank (Supabase Postgres) ---------------------------------------
# Supabase Dashboard -> Project Settings -> Database -> Connection string
# DATABASE_URL  = "Transaction pooler" URL (Port 6543) + ?pgbouncer=true
# DIRECT_URL    = "Direct connection" URL (Port 5432), wird von Prisma fuer db push genutzt
DATABASE_URL="postgresql://postgres.<project-ref>:<passwort>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:<passwort>@db.<project-ref>.supabase.co:5432/postgres"

# --- Supabase Storage (fuer Bild-Uploads in Produktion) -------------------
# Project Settings -> API. Bucket "uploads" (public) im Storage anlegen.
# Lokal weglassen -> Uploads landen in public/uploads
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# --- NextAuth --------------------------------------------------------------
# Generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Lokal: http://localhost:3003 / Produktion: https://<deine-cms-domain>
NEXTAUTH_URL="http://localhost:3003"

# --- Nur fuer prisma/seed.ts (ersten Admin anlegen) ------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme123"
